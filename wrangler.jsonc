{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "gistream-web",
  "compatibility_date": "2026-05-18",
  "main": "src/worker.ts",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
